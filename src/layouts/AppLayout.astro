---
// AppLayout.astro — Shell de la app con nav inferior
import BaseLayout from './BaseLayout.astro'
import BottomNav from '@/components/nav/BottomNav'

interface Props {
  title?: string
  description?: string
  activeNav?: string
}

const { title, description, activeNav = '/' } = Astro.props
---

<BaseLayout title={title} description={description}>
  <div class="app-shell">
    <main class="app-main content-with-nav" id="main-content">
      <slot />
    </main>
    <BottomNav client:load activeNav={activeNav} />
  </div>
</BaseLayout>

<style>
  .app-shell {
    display: flex;
    flex-direction: column;
    min-height: 100dvh;
    min-height: 100vh;
    background: var(--bg-base);
  }

  .app-main {
    flex: 1;
    width: 100%;
    max-width: 480px;
    margin-inline: auto;
    padding-inline: 1.25rem;
    padding-top: 1.5rem;
  }
</style>
