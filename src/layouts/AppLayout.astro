---
import BaseLayout from './BaseLayout.astro'
import BottomNav from '@/components/nav/BottomNav'
import SideNav from '@/components/nav/SideNav'
import AppShellClient from '@/components/AppShellClient'

interface Props {
  title?: string
  description?: string
  activeNav?: string
}

const { title, description, activeNav = '/' } = Astro.props
---

<BaseLayout title={title} description={description}>
  <div class="app-shell">

    <!-- SideNav — persists across navigations (no re-mount) -->
    <SideNav client:load activeNav={activeNav} transition:persist="sidenav" />

    <!-- Contenido principal — animated transition on page change -->
    <main class="app-main" id="main-content" tabindex="-1" transition:animate="fade">
      <slot />
    </main>

    <!-- BottomNav — persists across navigations (no re-mount) -->
    <BottomNav client:load activeNav={activeNav} transition:persist="bottomnav" />

    <!-- Toast global + seed init — persists -->
    <AppShellClient client:load transition:persist="appshell" />

  </div>
</BaseLayout>

<style>
  /* ── Shell root ─────────────────────────────── */
  .app-shell {
    display: flex;
    min-height: 100dvh;
    background: var(--bg-base);
  }

  /* ── Main content — mobile first ────────────── */
  .app-main {
    flex: 1;
    min-width: 0;
    width: 100%;
    /* Centered, max readable width */
    max-width: 560px;
    margin-inline: auto;
    padding-inline: 1.25rem;
    padding-top: 1.5rem;
    /* Clearance for floating bottom nav */
    padding-bottom: calc(96px + env(safe-area-inset-bottom, 0px));
    /* Smooth scroll */
    scroll-behavior: smooth;
  }

  /* ── Tablet (768–1023px): tab bar adds top clearance ── */
  @media (min-width: 768px) {
    .app-shell {
      flex-direction: column;
    }
    .app-main {
      /* Tab bar is 56px */
      padding-top: calc(56px + 1.5rem);
      /* No floating bottom nav on tablet */
      padding-bottom: 2.5rem;
      max-width: 680px;
    }
  }

  /* ── Desktop (≥1024px): sidebar left, content right ── */
  @media (min-width: 1024px) {
    .app-shell {
      flex-direction: row;
    }
    .app-main {
      /* Reset tablet top padding */
      padding-top: 2rem;
      padding-bottom: 2.5rem;
      max-width: 700px;
    }
  }

  @media (min-width: 1280px) {
    .app-main { max-width: 780px; }
  }
</style>